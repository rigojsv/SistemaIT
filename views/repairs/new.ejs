<div class="repairs-page">
    <div class="page-header">
        <h1>Nueva Solicitud de Reparación</h1>
    </div>

    <div class="card">
        <form class="form-grid">
            <div class="form-group">
                <label for="equipment">Equipo</label>
                <select id="equipment" class="form-control" required>
                    <option value="">Seleccionar equipo...</option>
                    <option value="1">Laptop HP EliteBook (SN123456)</option>
                    <option value="2">Desktop Dell OptiPlex (SN789012)</option>
                </select>
            </div>

            <div class="form-group">
                <label for="reportedBy">Reportado por</label>
                <select id="reportedBy" class="form-control" required>
                    <option value="">Seleccionar usuario...</option>
                    <option value="1">María González</option>
                    <option value="2">Carlos Ruiz</option>
                </select>
            </div>

            <div class="form-group">
                <label for="priority">Prioridad</label>
                <select id="priority" class="form-control" required>
                    <option value="low">Baja</option>
                    <option value="medium">Media</option>
                    <option value="high">Alta</option>
                    <option value="urgent">Urgente</option>
                </select>
            </div>

            <div class="form-group">
                <label for="technician">Técnico Asignado</label>
                <select id="technician" class="form-control" required>
                    <option value="">Asignar técnico...</option>
                    <option value="1">Juan Técnico</option>
                    <option value="2">Ana Técnico</option>
                </select>
            </div>

            <div class="form-group full-width">
                <label for="problem">Descripción del Problema</label>
                <textarea id="problem" class="form-control" rows="4" required></textarea>
            </div>

            <div class="form-group full-width">
                <label for="notes">Notas Adicionales</label>
                <textarea id="notes" class="form-control" rows="3"></textarea>
            </div>

            <div class="form-actions">
                <button type="button" class="btn btn-secondary" onclick="history.back()">Cancelar</button>
                <button type="submit" class="btn btn-primary">Crear Solicitud</button>
            </div>
        </form>
    </div>
</div>