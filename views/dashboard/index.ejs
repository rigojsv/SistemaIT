<div class="dashboard">
    <h1>Dashboard</h1>
    
    <div class="stats-grid">
        <div class="card">
            <h3>Total Equipos</h3>
            <div class="stat-value">150</div>
            <div class="stat-chart">
                <canvas id="equipmentChart"></canvas>
            </div>
        </div>
        
        <div class="card">
            <h3>Reparaciones Activas</h3>
            <div class="stat-value">12</div>
            <div class="stat-chart">
                <canvas id="repairsChart"></canvas>
            </div>
        </div>
        
        <div class="card">
            <h3>Asignaciones</h3>
            <div class="stat-value">125</div>
            <div class="stat-chart">
                <canvas id="assignmentsChart"></canvas>
            </div>
        </div>
    </div>

    <div class="card">
        <h3>Últimas Actividades</h3>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>2024-01-20</td>
                        <td>Reparación</td>
                        <td>Laptop HP - Cambio de disco duro</td>
                        <td>En proceso</td>
                    </tr>
                    <tr>
                        <td>2024-01-19</td>
                        <td>Asignación</td>
                        <td>Desktop Dell - Usuario: Juan Pérez</td>
                        <td>Completado</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Equipment Status Chart
    new Chart(document.getElementById('equipmentChart'), {
        type: 'doughnut',
        data: {
            labels: ['En uso', 'En reparación', 'Disponible'],
            datasets: [{
                data: [70, 15, 15],
                backgroundColor: ['#2563eb', '#dc2626', '#16a34a']
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });

    // Repairs Chart
    new Chart(document.getElementById('repairsChart'), {
        type: 'bar',
        data: {
            labels: ['Ene', 'Feb', 'Mar', 'Abr'],
            datasets: [{
                label: 'Reparaciones',
                data: [12, 19, 15, 12],
                backgroundColor: '#2563eb'
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });

    // Assignments Chart
    new Chart(document.getElementById('assignmentsChart'), {
        type: 'line',
        data: {
            labels: ['Ene', 'Feb', 'Mar', 'Abr'],
            datasets: [{
                label: 'Asignaciones',
                data: [100, 110, 120, 125],
                borderColor: '#2563eb',
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false
        }
    });
});
</script>